# Copy to .env and fill. Never commit .env.

# ── Core ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://postgres:postgres@localhost:5432/spotkey
REDIS_URL=redis://localhost:6379
PORT=3000

# ── Auth (Better Auth) ─────────────────────────────────────────────────────
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# ── CORS origins — only the surfaces in the App Profile ────────────────────
ADMIN_URL=http://localhost:3001
EXPO_PUBLIC_API_URL=http://localhost:3000

# ── SMS / OTP (msg91) ──────────────────────────────────────────────────────
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=

# ── Email (zeptomail) — carries the 7-day invoice, always sent ─────────────
ZEPTOMAIL_TOKEN=
ZEPTOMAIL_FROM=

# ── Push (FCM) ─────────────────────────────────────────────────────────────
FCM_SERVICE_ACCOUNT=

# ── Payments (Razorpay) ────────────────────────────────────────────────────
# MANDATE ONLY. Razorpay exists solely for the owner's UPI Autopay mandate on the
# 7-day platform fee. It is NEVER used for a parker-to-owner payment — that is
# external and untracked (docs/features/06-booking-flow.md).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Realtime ───────────────────────────────────────────────────────────────
SOCKET_IO_ORIGIN=http://localhost:3001

# ── WhatsApp — BSP not yet chosen (Known Gotcha 5) ─────────────────────────
# WHATSAPP_PROVIDER=
# WHATSAPP_TOKEN=
